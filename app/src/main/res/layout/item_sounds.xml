<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Sound Title -->
        <TextView
            android:id="@+id/text_sound_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/button_favorite"
            android:text="Sound Effect Name"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Sound Category -->
        <TextView
            android:id="@+id/text_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_sound_title"
            android:layout_toStartOf="@id/button_favorite"
            android:text="Category"
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Favorite Button -->
        <ImageButton
            android:id="@+id/button_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add to favorites"
            android:padding="8dp"
            android:src="@android:drawable/btn_star" />

        <!-- Play Button -->
        <Button
            android:id="@+id/button_play"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_category"
            android:layout_marginTop="8dp"
            android:backgroundTint="#42f55d"
            android:text="PLAY"
            android:textColor="@color/black" />

        <!-- Audio Wave Visualization (Optional) -->
        <ProgressBar
            android:id="@+id/progress_playing"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_below="@id/button_play"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Sound Duration -->
        <TextView
            android:id="@+id/text_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/button_play"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:text="0:00"
            android:textColor="#666666"
            android:textSize="12sp" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>